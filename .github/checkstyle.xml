<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtd/configuration_1_3.dtd">

<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">

        <!-- ===================== -->
        <!--        NAMING         -->
        <!-- ===================== -->

        <!-- Class names: PascalCase, singular enforced by developer -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Exception classes must end with "Exception" -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*Exception$"/>
            <property name="tokens" value="CLASS_DEF"/>
            <property name="applyToPublic" value="true"/>
        </module>

        <!-- Method names: lowerCamelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Variable names: lowerCamelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Constants: SCREAMING_SNAKE_CASE -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- Accessor/mutator naming: get*, set*, is* -->
        <module name="MethodName">
            <property name="format" value="^(get|set|is)[A-Z][a-zA-Z0-9]*$|^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- ===================== -->
        <!--        LAYOUT         -->
        <!-- ===================== -->

        <!-- 4 spaces indentation, no tabs -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\t"/>
            <property name="message" value="Use 4 spaces for indentation, not tabs."/>
        </module>

        <!-- Allman style braces (opening brace on new line) -->
        <module name="LeftCurly">
            <property name="option" value="nl"/>
        </module>
        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>

        <!-- Always use curly braces in control structures -->
        <module name="NeedBraces">
            <property name="tokens" value="LITERAL_IF, LITERAL_ELSE, LITERAL_WHILE, LITERAL_DO, LITERAL_FOR"/>
        </module>

        <!-- Space around operators -->
        <module name="WhitespaceAround">
            <property name="tokens" value="ASSIGN, PLUS, MINUS, STAR, MOD, DIV,
                PLUS_ASSIGN, MINUS_ASSIGN, STAR_ASSIGN, DIV_ASSIGN,
                EQUAL, NOT_EQUAL, LT, GT, LE, GE"/>
            <property name="allowEmptyMethods" value="false"/>
        </module>

        <!-- No space between method name and opening parenthesis -->
        <module name="MethodParamPad">
            <property name="option" value="nospace"/>
        </module>

        <!-- Space after commas in parameters -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA"/>
        </module>

        <!-- Space between keywords (if, while, for) and opening parenthesis -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="LITERAL_IF, LITERAL_WHILE, LITERAL_FOR"/>
        </module>

        <!-- No space for ++ and - operators -->
        <module name="NoWhitespaceAfter">
            <property name="tokens" value="INC, DEC"/>
        </module>
        <module name="NoWhitespaceBefore">
            <property name="tokens" value="INC, DEC"/>
        </module>

        <!-- Blank line between methods -->
        <module name="EmptyLineSeparator">
            <property name="tokens" value="METHOD_DEF, CTOR_DEF"/>
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
        </module>

        <!-- Fields declared before constructors and methods -->
        <module name="DeclarationOrder">
            <property name="ignoreConstructors" value="false"/>
            <property name="ignoreMethods" value="false"/>
        </module>

        <!-- Enum constants each on their own line -->
        <module name="Regexp">
            <property name="format" value=",\s*[A-Z]"/>
            <property name="message" value="Each enum constant must be on its own line."/>
            <property name="illegalPattern" value="true"/>
        </module>

        <!-- this. prefix enforced via RequireThis -->
        <module name="RequireThis">
            <property name="checkFields" value="true"/>
            <property name="checkMethods" value="true"/>
            <property name="validateOnlyOverlapping" value="false"/>
        </module>

    </module>
</module>